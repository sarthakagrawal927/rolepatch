# Turso
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# AI Provider (OpenAI-compatible endpoint via @saas-maker/ai)
AI_BASE_URL=https://your-ai-gateway/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=auto

# Auth (NextAuth v5 / Auth.js)
# v5 reads AUTH_SECRET / AUTH_URL by default; NEXTAUTH_SECRET / NEXTAUTH_URL are also accepted for back-compat.
AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_URL=http://localhost:3000   # optional; needed in prod if the deployed URL cannot be auto-detected
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SaasMaker
NEXT_PUBLIC_SAASMAKER_API_KEY=your-saasmaker-project-key

# Dodo Payments
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-webhook-secret
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/pricing?success=true
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Dodo Product IDs (create in Dodo dashboard)
DODO_PRODUCT_STARTER=pdt_xxx
DODO_PRODUCT_PRO=pdt_xxx
DODO_PRODUCT_BULK=pdt_xxx

# JobSpy Python serverless function at api/python/jobs-search.py
# Shared secret between the Next.js proxy and the Python function (same deploy).
JOBSPY_API_KEY=your-shared-secret
