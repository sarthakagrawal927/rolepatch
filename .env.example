# Database
# Production persistence uses the Cloudflare D1 binding configured in wrangler.toml.
# No database URL/token is required for the deployed Worker.

# AI Provider — defaults to free-ai-gateway (Fleet-wide Workers AI chokepoint
# with daily Neuron budget). Override AI_BASE_URL only for local gateways or
# alternate deployments.
AI_BASE_URL=https://free-ai-gateway.sarthakagrawal927.workers.dev/v1
# AI_GATEWAY_API_KEY — Bearer token for free-ai-gateway /v1/* auth enforcement.
# Generate with: openssl rand -hex 32. Set as wrangler secret.
AI_GATEWAY_API_KEY=
# AI_API_KEY is a legacy alias — prefer AI_GATEWAY_API_KEY
AI_API_KEY=
AI_MODEL=auto

# Auth (better-auth)
# better-auth reads BETTER_AUTH_SECRET / BETTER_AUTH_URL.
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
# BETTER_AUTH_URL=http://localhost:3000   # optional; needed in prod if the deployed URL cannot be auto-detected
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SaasMaker
NEXT_PUBLIC_SAASMAKER_API_KEY=your-saasmaker-project-key

# Dodo Payments
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-webhook-secret
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/pricing?success=true
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Dodo Product IDs (create in Dodo dashboard)
DODO_PRODUCT_STARTER=pdt_xxx
DODO_PRODUCT_PRO=pdt_xxx
DODO_PRODUCT_BULK=pdt_xxx
